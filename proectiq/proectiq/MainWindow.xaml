<Window x:Class="proectiq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:proectiq"
        mc:Ignorable="d"
        Title="Управление партнерами и продукцией" Height="700" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Label Content="Управление партнерами и историей продаж"
                   FontSize="20" FontWeight="Bold" Foreground="White"
                   HorizontalAlignment="Center"/>
        </Border>

        <!-- Список партнеров -->
        <GroupBox Grid.Row="1" Header="Список партнеров" Margin="10" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListView Grid.Row="0" Name="listPartner"
                          SelectionChanged="ListPartner_SelectionChanged"
                          MouseDoubleClick="ListPartner_MouseDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding ID}"/>
                            <GridViewColumn Header="Тип" Width="80" DisplayMemberBinding="{Binding Тип_партнера}"/>
                            <GridViewColumn Header="Наименование" Width="180" DisplayMemberBinding="{Binding Наименование_партнера}"/>
                            <GridViewColumn Header="Директор" Width="150" DisplayMemberBinding="{Binding Директор}"/>
                            <GridViewColumn Header="Телефон" Width="120" DisplayMemberBinding="{Binding Телефон_партнера}"/>
                            <GridViewColumn Header="Рейтинг" Width="80" DisplayMemberBinding="{Binding Рейтинг}"/>
                            <GridViewColumn Header="Скидка" Width="60" DisplayMemberBinding="{Binding Скидка}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                    <Button x:Name="btnAddPartner" Content="➕ Добавить" Width="100" Margin="2"
                            Click="BtnAddPartner_Click" Background="#27AE60" Foreground="White"/>
                    <Button x:Name="btnEditPartner" Content="✏️ Изменить" Width="100" Margin="2"
                            Click="BtnEditPartner_Click" Background="#3498DB" Foreground="White"/>
                    <Button x:Name="btnDeletePartner" Content="🗑️ Удалить" Width="100" Margin="2"
                            Click="BtnDeletePartner_Click" Background="#E74C3C" Foreground="White"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Информация о выбранном партнере -->
        <GroupBox Grid.Row="2" Header="Информация о партнере" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Тип партнера:" FontWeight="Bold"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtType" Margin="5"/>
                <Label Grid.Row="0" Grid.Column="2" Content="Наименование:" FontWeight="Bold"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtName" Margin="5"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Директор:" FontWeight="Bold"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDirector" Margin="5"/>
                <Label Grid.Row="1" Grid.Column="2" Content="Телефон:" FontWeight="Bold"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="txtPhone" Margin="5"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Email:" FontWeight="Bold"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtEmail" Margin="5"/>
                <Label Grid.Row="2" Grid.Column="2" Content="Рейтинг:" FontWeight="Bold"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="txtRating" Margin="5"/>

                <Label Grid.Row="3" Grid.Column="0" Content="Юр. адрес:" FontWeight="Bold"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtAddress" Margin="5" Grid.ColumnSpan="3"/>

                <Label Grid.Row="4" Grid.Column="0" Content="ИНН:" FontWeight="Bold"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtINN" Margin="5"/>

                <Label Grid.Row="4" Grid.Column="2" Content="Скидка:" FontWeight="Bold" Foreground="Green"/>
                <Label Grid.Row="4" Grid.Column="3" x:Name="lblDiscount" Content="0%" Margin="5"
                       Foreground="Green" FontWeight="Bold" FontSize="14"/>
            </Grid>
        </GroupBox>

        <!-- История покупок -->
        <GroupBox Grid.Row="3" Header="История покупок партнера" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListView Grid.Row="0" Name="listHistory"
                          SelectionChanged="ListHistory_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding ID}"/>
                            <GridViewColumn Header="ID Продукта" Width="80" DisplayMemberBinding="{Binding ID_Product}"/>
                            <GridViewColumn Header="Наименование продукции" Width="250" DisplayMemberBinding="{Binding ProductName}"/>
                            <GridViewColumn Header="Количество" Width="100" DisplayMemberBinding="{Binding Quantity}"/>
                            <GridViewColumn Header="Дата продажи" Width="120" DisplayMemberBinding="{Binding SaleDate}"/>
                            <GridViewColumn Header="Стоимость" Width="120" DisplayMemberBinding="{Binding Cost}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Продукт:" Margin="5"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbProduct"
                                  DisplayMemberPath="Наименование_продукции" SelectedValuePath="ID" Margin="5"/>

                        <Label Grid.Row="0" Grid.Column="2" Content="Количество:" Margin="5"/>
                        <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtQuantity" Margin="5" Width="100"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Дата продажи:" Margin="5"/>
                        <DatePicker Grid.Row="1" Grid.Column="1" x:Name="dpSaleDate" Margin="5"/>

                        <StackPanel Grid.Row="0" Grid.Column="4" Grid.RowSpan="2" Orientation="Vertical" Margin="5">
                            <Button x:Name="btnAddHistory" Content="➕ Добавить" Width="100" Margin="2"
                                    Click="BtnAddHistory_Click" Background="#27AE60" Foreground="White"/>
                            <Button x:Name="btnEditHistory" Content="✏️ Изменить" Width="100" Margin="2"
                                    Click="BtnEditHistory_Click" Background="#3498DB" Foreground="White"/>
                            <Button x:Name="btnDeleteHistory" Content="🗑️ Удалить" Width="100" Margin="2"
                                    Click="BtnDeleteHistory_Click" Background="#E74C3C" Foreground="White"/>
                            <Button x:Name="btnClearHistory" Content="🔄 Очистить" Width="100" Margin="2"
                                    Click="BtnClearHistory_Click" Background="#95A5A6" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>
    </Grid>
</Window>